<w:document xmlns:wpc="http://schemas.microsoft.com/office/word/2010/wordprocessingCanvas" xmlns:cx="http://schemas.microsoft.com/office/drawing/2014/chartex" xmlns:cx1="http://schemas.microsoft.com/office/drawing/2015/9/8/chartex" xmlns:cx2="http://schemas.microsoft.com/office/drawing/2015/10/21/chartex" xmlns:cx3="http://schemas.microsoft.com/office/drawing/2016/5/9/chartex" xmlns:cx4="http://schemas.microsoft.com/office/drawing/2016/5/10/chartex" xmlns:cx5="http://schemas.microsoft.com/office/drawing/2016/5/11/chartex" xmlns:cx6="http://schemas.microsoft.com/office/drawing/2016/5/12/chartex" xmlns:cx7="http://schemas.microsoft.com/office/drawing/2016/5/13/chartex" xmlns:cx8="http://schemas.microsoft.com/office/drawing/2016/5/14/chartex" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:aink="http://schemas.microsoft.com/office/drawing/2016/ink" xmlns:am3d="http://schemas.microsoft.com/office/drawing/2017/model3d" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:oel="http://schemas.microsoft.com/office/2019/extlst" xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships" xmlns:m="http://schemas.openxmlformats.org/officeDocument/2006/math" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:wp14="http://schemas.microsoft.com/office/word/2010/wordprocessingDrawing" xmlns:wp="http://schemas.openxmlformats.org/drawingml/2006/wordprocessingDrawing" xmlns:w10="urn:schemas-microsoft-com:office:word" xmlns:w="http://schemas.openxmlformats.org/wordprocessingml/2006/main" xmlns:w14="http://schemas.microsoft.com/office/word/2010/wordml" xmlns:w15="http://schemas.microsoft.com/office/word/2012/wordml" xmlns:w16cex="http://schemas.microsoft.com/office/word/2018/wordml/cex" xmlns:w16cid="http://schemas.microsoft.com/office/word/2016/wordml/cid" xmlns:w16="http://schemas.microsoft.com/office/word/2018/wordml" xmlns:w16du="http://schemas.microsoft.com/office/word/2023/wordml/word16du" xmlns:w16sdtdh="http://schemas.microsoft.com/office/word/2020/wordml/sdtdatahash" xmlns:w16sdtfl="http://schemas.microsoft.com/office/word/2024/wordml/sdtformatlock" xmlns:w16se="http://schemas.microsoft.com/office/word/2015/wordml/symex" xmlns:wpg="http://schemas.microsoft.com/office/word/2010/wordprocessingGroup" xmlns:wpi="http://schemas.microsoft.com/office/word/2010/wordprocessingInk" xmlns:wne="http://schemas.microsoft.com/office/word/2006/wordml" xmlns:wps="http://schemas.microsoft.com/office/word/2010/wordprocessingShape" mc:Ignorable="w14 w15 w16se w16cid w16 w16cex w16sdtdh w16sdtfl w16du wp14"><w:body><w:p w14:paraId="543E6F62" w14:textId="77777777" w:rsidR="00220A53" w:rsidRPr="00220A53" w:rsidRDefault="00220A53" w:rsidP="00220A53"><w:r w:rsidRPr="00220A53"><w:t>A </w:t></w:r><w:r w:rsidRPr="00220A53"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>MentALL.Vet</w:t></w:r><w:r w:rsidRPr="00220A53"><w:t> é a unidade do Ecossistema Chordata dedicada exclusivamente à </w:t></w:r><w:r w:rsidRPr="00220A53"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>saúde mental e ao bem-estar</w:t></w:r><w:r w:rsidRPr="00220A53"><w:t> de médicos-veterinários, estudantes e equipes do setor. Sua estrutura é desenhada para combater os altos índices de burnout no setor — que afetam 72% dos profissionais — através de suporte especializado e treinamentos.</w:t></w:r></w:p><w:p w14:paraId="7A43DF82" w14:textId="77777777" w:rsidR="00220A53" w:rsidRPr="00220A53" w:rsidRDefault="00220A53" w:rsidP="00220A53"><w:r w:rsidRPr="00220A53"><w:t>Abaixo detalho toda a estrutura de serviços e programas oferecidos:</w:t></w:r></w:p><w:p w14:paraId="18E2876C" w14:textId="77777777" w:rsidR="00220A53" w:rsidRPr="00220A53" w:rsidRDefault="00220A53" w:rsidP="00220A53"><w:r w:rsidRPr="00220A53"><w:t>1. Serviços de Atendimento e Suporte</w:t></w:r></w:p><w:p w14:paraId="45720430" w14:textId="77777777" w:rsidR="00220A53" w:rsidRPr="00220A53" w:rsidRDefault="00220A53" w:rsidP="00220A53"><w:r w:rsidRPr="00220A53"><w:t>A MentALL.Vet oferece diferentes modalidades de suporte psicológico e consultivo:</w:t></w:r></w:p><w:p w14:paraId="421789FE" w14:textId="77777777" w:rsidR="00220A53" w:rsidRPr="00220A53" w:rsidRDefault="00220A53" w:rsidP="00220A53"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr></w:pPr><w:r w:rsidRPr="00220A53"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Psicoterapia Individual:</w:t></w:r><w:r w:rsidRPr="00220A53"><w:t> Atendimento online ou presencial com profissionais que compreendem a rotina e os desafios emocionais da medicina veterinária.</w:t></w:r></w:p><w:p w14:paraId="1C15A5F9" w14:textId="77777777" w:rsidR="00220A53" w:rsidRPr="00220A53" w:rsidRDefault="00220A53" w:rsidP="00220A53"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr></w:pPr><w:r w:rsidRPr="00220A53"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Planos Corporativos:</w:t></w:r><w:r w:rsidRPr="00220A53"><w:t> Programas de psicoterapia voltados para clínicas e hospitais, cobrindo equipes de até 20 colaboradores.</w:t></w:r></w:p><w:p w14:paraId="058D0CFD" w14:textId="77777777" w:rsidR="00220A53" w:rsidRPr="00220A53" w:rsidRDefault="00220A53" w:rsidP="00220A53"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr></w:pPr><w:r w:rsidRPr="00220A53"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Programa EAI Vet (Escuta Ativa Individualizada):</w:t></w:r><w:r w:rsidRPr="00220A53"><w:t> Um suporte emocional estruturado que inclui a geração de relatórios e insights para a gestão de RH das empresas.</w:t></w:r></w:p><w:p w14:paraId="0F37FCFC" w14:textId="77777777" w:rsidR="00220A53" w:rsidRPr="00220A53" w:rsidRDefault="00220A53" w:rsidP="00220A53"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr></w:pPr><w:r w:rsidRPr="00220A53"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Consultoria de RH Especializada:</w:t></w:r><w:r w:rsidRPr="00220A53"><w:t> Projetos customizáveis de gestão de pessoas com foco direto em saúde mental e bem-estar organizacional.</w:t></w:r></w:p><w:p w14:paraId="71F1166D" w14:textId="77777777" w:rsidR="00220A53" w:rsidRPr="00220A53" w:rsidRDefault="00220A53" w:rsidP="00220A53"><w:r w:rsidRPr="00220A53"><w:t>2. Programas de Treinamento</w:t></w:r></w:p><w:p w14:paraId="48F64D5B" w14:textId="77777777" w:rsidR="00220A53" w:rsidRPr="00220A53" w:rsidRDefault="00220A53" w:rsidP="00220A53"><w:r w:rsidRPr="00220A53"><w:t>A estrutura de treinamentos é dividida em dois pilares principais: lideranças e equipes.</w:t></w:r></w:p><w:p w14:paraId="2C027C58" w14:textId="77777777" w:rsidR="00220A53" w:rsidRPr="00220A53" w:rsidRDefault="00220A53" w:rsidP="00220A53"><w:r w:rsidRPr="00220A53"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Para Lideranças (Foco em Gestão Humanizada):</w:t></w:r></w:p><w:p w14:paraId="7668FF1A" w14:textId="77777777" w:rsidR="00220A53" w:rsidRPr="00220A53" w:rsidRDefault="00220A53" w:rsidP="00220A53"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r w:rsidRPr="00220A53"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Liderança que Cuida:</w:t></w:r><w:r w:rsidRPr="00220A53"><w:t> Workshop de 8h sobre empatia e comunicação.</w:t></w:r></w:p><w:p w14:paraId="350F7F0F" w14:textId="77777777" w:rsidR="00220A53" w:rsidRPr="00220A53" w:rsidRDefault="00220A53" w:rsidP="00220A53"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r w:rsidRPr="00220A53"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Inteligência Emocional para Líderes:</w:t></w:r><w:r w:rsidRPr="00220A53"><w:t> Foco em gerenciar pessoas e emoções sob pressão.</w:t></w:r></w:p><w:p w14:paraId="2E8A2A9B" w14:textId="77777777" w:rsidR="00220A53" w:rsidRPr="00220A53" w:rsidRDefault="00220A53" w:rsidP="00220A53"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r w:rsidRPr="00220A53"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Criando Ambientes Seguros:</w:t></w:r><w:r w:rsidRPr="00220A53"><w:t> Psicologia organizacional aplicada para gerar segurança psicológica e confiança.</w:t></w:r></w:p><w:p w14:paraId="05915314" w14:textId="77777777" w:rsidR="00220A53" w:rsidRPr="00220A53" w:rsidRDefault="00220A53" w:rsidP="00220A53"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r w:rsidRPr="00220A53"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Outros módulos:</w:t></w:r><w:r w:rsidRPr="00220A53"><w:t> Melhores Práticas de Feedback, Comunicação Estratégica e Liderar com Propósito.</w:t></w:r></w:p><w:p w14:paraId="332CE6C8" w14:textId="77777777" w:rsidR="00220A53" w:rsidRPr="00220A53" w:rsidRDefault="00220A53" w:rsidP="00220A53"><w:r w:rsidRPr="00220A53"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Para Equipes (Foco em Coesão e Engajamento):</w:t></w:r></w:p><w:p w14:paraId="5C9E4931" w14:textId="77777777" w:rsidR="00220A53" w:rsidRPr="00220A53" w:rsidRDefault="00220A53" w:rsidP="00220A53"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="3"/></w:numPr></w:pPr><w:r w:rsidRPr="00220A53"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Cuidar de Quem Cuida:</w:t></w:r><w:r w:rsidRPr="00220A53"><w:t> Workshop de 6h sobre inteligência emocional e relacionamentos saudáveis.</w:t></w:r></w:p><w:p w14:paraId="3F6AC207" w14:textId="77777777" w:rsidR="00220A53" w:rsidRPr="00220A53" w:rsidRDefault="00220A53" w:rsidP="00220A53"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="3"/></w:numPr></w:pPr><w:r w:rsidRPr="00220A53"><w:rPr><w:b/><w:bCs/></w:rPr><w:lastRenderedPageBreak/><w:t>Falar Sem Medo:</w:t></w:r><w:r w:rsidRPr="00220A53"><w:t> Comunicação aberta e construção de segurança psicológica na equipe.</w:t></w:r></w:p><w:p w14:paraId="7DA26F97" w14:textId="77777777" w:rsidR="00220A53" w:rsidRPr="00220A53" w:rsidRDefault="00220A53" w:rsidP="00220A53"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="3"/></w:numPr></w:pPr><w:r w:rsidRPr="00220A53"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Nossa Cultura, Nossa Clínica:</w:t></w:r><w:r w:rsidRPr="00220A53"><w:t> Fortalecimento do sentimento de pertencimento e identidade coletiva.</w:t></w:r></w:p><w:p w14:paraId="5B9FE705" w14:textId="77777777" w:rsidR="00220A53" w:rsidRPr="00220A53" w:rsidRDefault="00220A53" w:rsidP="00220A53"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="3"/></w:numPr></w:pPr><w:r w:rsidRPr="00220A53"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Outros módulos:</w:t></w:r><w:r w:rsidRPr="00220A53"><w:t> Feedback 360°, Onboarding (Bem-vindo à Equipe), Propósito e Comunicação Eficaz.</w:t></w:r></w:p><w:p w14:paraId="206E8BB3" w14:textId="77777777" w:rsidR="00220A53" w:rsidRPr="00220A53" w:rsidRDefault="00220A53" w:rsidP="00220A53"><w:r w:rsidRPr="00220A53"><w:t>3. Integração e Parcerias</w:t></w:r></w:p><w:p w14:paraId="4BF2268C" w14:textId="77777777" w:rsidR="00220A53" w:rsidRPr="00220A53" w:rsidRDefault="00220A53" w:rsidP="00220A53"><w:r w:rsidRPr="00220A53"><w:t>A MentALL.Vet não atua de forma isolada, mas sim integrada ao ecossistema:</w:t></w:r></w:p><w:p w14:paraId="23BD9E81" w14:textId="77777777" w:rsidR="00220A53" w:rsidRPr="00220A53" w:rsidRDefault="00220A53" w:rsidP="00220A53"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="4"/></w:numPr></w:pPr><w:r w:rsidRPr="00220A53"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Sinergia com Consultoria:</w:t></w:r><w:r w:rsidRPr="00220A53"><w:t> Enquanto a Chordata Consultoria estrutura processos e estratégias, a MentALL.Vet cuida do fator humano para garantir que a transformação do negócio seja sustentável.</w:t></w:r></w:p><w:p w14:paraId="3C7685F1" w14:textId="77777777" w:rsidR="00220A53" w:rsidRPr="00220A53" w:rsidRDefault="00220A53" w:rsidP="00220A53"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="4"/></w:numPr></w:pPr><w:r w:rsidRPr="00220A53"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Parceria Vet Family Brasil:</w:t></w:r><w:r w:rsidRPr="00220A53"><w:t> A MentALL.Vet está integrada à maior comunidade veterinária do Brasil, oferecendo condições especiais, psicoterapia e programas corporativos para seus membros.</w:t></w:r></w:p><w:p w14:paraId="29FD488B" w14:textId="77777777" w:rsidR="00220A53" w:rsidRPr="00220A53" w:rsidRDefault="00220A53" w:rsidP="00220A53"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="4"/></w:numPr></w:pPr><w:r w:rsidRPr="00220A53"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Impacto Mensurável:</w:t></w:r><w:r w:rsidRPr="00220A53"><w:t> A implementação desses serviços visa resultados como a </w:t></w:r><w:r w:rsidRPr="00220A53"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>redução de até 60% no turnover</w:t></w:r><w:r w:rsidRPr="00220A53"><w:t> e de </w:t></w:r><w:r w:rsidRPr="00220A53"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>45% no absenteísmo</w:t></w:r><w:r w:rsidRPr="00220A53"><w:t>, além de melhorar o clima organizacional (NPS) em cerca de 40 pontos.</w:t></w:r></w:p><w:p w14:paraId="74D4B5BD" w14:textId="77777777" w:rsidR="00220A53" w:rsidRPr="00220A53" w:rsidRDefault="00220A53" w:rsidP="00220A53"><w:r w:rsidRPr="00220A53"><w:t>Dependendo do porte do negócio, os serviços da MentALL.Vet podem ser incluídos em pacotes mensais, indo desde o atendimento individual para autônomos até programas corporativos completos para hospitais de grande porte.</w:t></w:r></w:p><w:p w14:paraId="230AA080" w14:textId="77777777" w:rsidR="002F7312" w:rsidRDefault="002F7312"/><w:sectPr w:rsidR="002F7312"><w:pgSz w:w="11906" w:h="16838"/><w:pgMar w:top="1417" w:right="1701" w:bottom="1417" w:left="1701" w:header="708" w:footer="708" w:gutter="0"/><w:cols w:space="708"/><w:docGrid w:linePitch="360"/></w:sectPr></w:body></w:document>
